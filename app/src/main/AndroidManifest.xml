<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.Simbalita"
        tools:targetApi="31">
        
        <!-- Launcher Splash Activity -->
        <activity
            android:name=".ui.auth.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.Design.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Auth Screens -->
        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        
        <activity
            android:name=".ui.auth.RegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.auth.ForgotPasswordActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Ibu Screens -->
        <activity
            android:name=".ui.ibu.IbuMainActivity"
            android:exported="false" />
        
        <activity
            android:name=".ui.ibu.RiwayatPemeriksaanActivity"
            android:exported="false" />
        
        <activity
            android:name=".ui.ibu.DetailPemeriksaanActivity"
            android:exported="false" />
        <activity
            android:name=".ui.ibu.BiodataIbuActivity"
            android:exported="false" />

        <activity
            android:name=".ui.ibu.BiodataAnakActivity"
            android:exported="false" />

        <activity
            android:name=".ui.ibu.KmsActivity"
            android:exported="false" />

        <activity
            android:name=".ui.ibu.ImunisasiActivity"
            android:exported="false" />

        <!-- Admin Screens -->
        <activity
            android:name=".ui.admin.AdminMainActivity"
            android:exported="false" />
        
        <activity
            android:name=".ui.admin.AddChildActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
            
        <activity
            android:name=".ui.admin.AddScheduleActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.admin.PemeriksaanBalitaActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.admin.DataPesertaActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

    </application>

</manifest>
