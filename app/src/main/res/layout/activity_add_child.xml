<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_admin"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Header back button -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp">

        <ImageView
            android:id="@+id/btn_back_add_child"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentStart="true"
            android:src="@drawable/ic_back"
            app:tint="@color/white"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back" />

    </RelativeLayout>

    <!-- Main Container Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="TAMBAH PESERTA"
                android:textColor="@color/black"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- Scrollable form contents -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Nama Balita -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nama Balita"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />
                    <EditText
                        android:id="@+id/et_add_child_name"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input_blue"
                        android:textColor="@color/white"
                        android:textColorHint="#DDDDDD"
                        android:textSize="15sp"
                        android:paddingHorizontal="16dp"
                        android:singleLine="true"
                        android:layout_marginBottom="16dp" />

                    <!-- Tanggal Lahir -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tanggal Lahir"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />
                    <EditText
                        android:id="@+id/et_add_child_birth_date"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input_blue"
                        android:textColor="@color/white"
                        android:textColorHint="#DDDDDD"
                        android:textSize="15sp"
                        android:paddingHorizontal="16dp"
                        android:focusable="false"
                        android:clickable="true"
                        android:hint="Pilih tanggal..."
                        android:layout_marginBottom="16dp" />

                    <!-- Jenis Kelamin -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Jenis Kelamin"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />
                    <!-- Use standard Spinner with custom blue background -->
                    <Spinner
                        android:id="@+id/sp_add_child_gender"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input_blue"
                        android:layout_marginBottom="16dp" />

                    <!-- Berat Lahir -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Berat Lahir (Kg)"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />
                    <EditText
                        android:id="@+id/et_add_child_weight"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input_blue"
                        android:textColor="@color/white"
                        android:textColorHint="#DDDDDD"
                        android:textSize="15sp"
                        android:paddingHorizontal="16dp"
                        android:inputType="numberDecimal"
                        android:singleLine="true"
                        android:layout_marginBottom="16dp" />

                    <!-- Tinggi Lahir -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tinggi Lahir (Cm)"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />
                    <EditText
                        android:id="@+id/et_add_child_height"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input_blue"
                        android:textColor="@color/white"
                        android:textColorHint="#DDDDDD"
                        android:textSize="15sp"
                        android:paddingHorizontal="16dp"
                        android:inputType="numberDecimal"
                        android:singleLine="true"
                        android:layout_marginBottom="16dp" />

                    <!-- Nama Ibu -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nama Ibu"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />
                    <!-- Use standard Spinner with custom blue background -->
                    <Spinner
                        android:id="@+id/sp_add_child_mother"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input_blue"
                        android:layout_marginBottom="24dp" />

                </LinearLayout>

            </ScrollView>

            <!-- Save Button -->
            <android.widget.Button
                android:id="@+id/btn_add_child_save"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_btn_blue"
                android:text="SIMPAN"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>
