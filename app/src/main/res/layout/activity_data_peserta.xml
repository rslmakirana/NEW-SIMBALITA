<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_admin"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Header Layout (Back arrow only) -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp">

        <ImageView
            android:id="@+id/btn_back_data_peserta"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentStart="true"
            android:src="@drawable/ic_back"
            app:tint="@color/white"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back" />

    </RelativeLayout>

    <!-- Main Container Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="DATA PESERTA"
                android:textColor="@color/black"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- Search input bar -->
            <EditText
                android:id="@+id/et_search_peserta"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_edittext"
                android:hint="Cari nama balita..."
                android:textColorHint="@color/text_secondary"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:paddingHorizontal="16dp"
                android:drawableEnd="@drawable/ic_search"
                app:drawableTint="@color/text_secondary"
                android:singleLine="true"
                android:layout_marginBottom="16dp" />

            <!-- RecyclerView for participant list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_peserta_list"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="16dp" />

            <!-- Tambah Peserta Button -->
            <android.widget.Button
                android:id="@+id/btn_tambah_peserta"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_btn_blue"
                android:text="TAMBAH PESERTA"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>
