<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app">

    <!-- Top Header Bar -->
    <View
        android:id="@+id/v_peserta_header"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/primary_admin"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Data Peserta"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/v_peserta_header"
        app:layout_constraintBottom_toBottomOf="@id/v_peserta_header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/iv_peserta_add"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="16dp"
        android:src="@drawable/ic_plus"
        app:tint="@color/white"
        app:layout_constraintTop_toTopOf="@id/v_peserta_header"
        app:layout_constraintBottom_toBottomOf="@id/v_peserta_header"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Search Box -->
    <FrameLayout
        android:id="@+id/fl_peserta_search"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/v_peserta_header">

        <EditText
            android:id="@+id/et_peserta_search"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_edittext"
            android:hint="@string/search_hint"
            android:inputType="text"
            android:paddingStart="44dp"
            android:paddingEnd="16dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="14dp"
            android:src="@drawable/ic_search"
            app:tint="@color/text_secondary" />

    </FrameLayout>

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_peserta"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/fl_peserta_search"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Empty State -->
    <TextView
        android:id="@+id/tv_peserta_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Belum ada data balita."
        android:textColor="@color/text_secondary"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/fl_peserta_search"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
