<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="176dp"
    android:background="@color/primary_ibu"
    android:gravity="bottom"
    android:orientation="vertical"
    android:padding="20dp"
    android:theme="@style/ThemeOverlay.AppCompat.Dark">

    <ImageView
        android:id="@+id/iv_nav_child_avatar"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ic_child"
        android:background="@color/status_normal_light"
        app:tint="@color/primary_ibu"
        android:padding="12dp"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tv_nav_child_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Belum Ada Anak"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_nav_child_age"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hubungi Kader untuk mendaftar"
        android:textColor="@color/primary_light_ibu"
        android:textSize="13sp"
        android:layout_marginTop="2dp" />

    <TextView
        android:id="@+id/tv_nav_view_profile"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lihat Profil Lengkap ›"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginTop="4dp"
        android:clickable="true"
        android:focusable="true"/>

</LinearLayout>
